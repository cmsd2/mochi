1845277101934,2.0799459823548663,2.009569210431623,1.9371265606864245,1.8626925056294463,1.7863435649758301,1.7081582269818694,1.6282168677574906,1.5466016686379875,1.4633965316999449,1.378686993508205,1.2925601371825475,1.2051045028744811,1.116409996746174,1.0265677985451012,0.935670267869417,0.8438108492204197,0.7510839759397129,0.6575849731298189,0.5634099596580437,0.4686557493443363,0.37341975143472206,0.2777998704626316,0.18189440560103776,0.08580194960894773,-0.010378712523969639,-0.10654870513034748,-0.20260916351130817,-0.2984613355713747,-0.3940066833376238,-0.4891469842587162,-0.5837844321796677,-0.6778217378885559,-0.7711622291317994,-0.8637099499951908],\"type\":\"scatter\",\"mode\":\"lines\",\"line\":{\"color\":\"gray\",\"width\":2,\"dash\":\"dash\"},\"name\":\"3 sin(2t) (input)\"}],\"layout\":{\"title\":{\"text\":\"Pendulum forced by tau(t) = 3 sin(2t)\"},\"showlegend\":true,\"width\":700,\"height\":450,\"plot_bgcolor\":\"white\",\"paper_bgcolor\":\"white\",\"xaxis\":{\"title\":{\"text\":\"t (s)\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1},\"yaxis\":{\"title\":{\"text\":\"theta (rad)  /  tau (N·m)\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1}}}"
